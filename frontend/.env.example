# ── API ──────────────────────────────────────────────────────────
# Backend base URL — include /api/v1 path prefix
# Default matches local FastAPI dev server (uvicorn app.main:app --reload)
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ── Auth0 (optional) ─────────────────────────────────────────────
# Leave blank to disable Auth0 — the platform uses its own JWT auth by default.
# Set both values to enable the "Continue with Auth0" button on the login page.
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
