# SentinelX Desktop Agent Configuration
# Copy this file to .env and edit the values before running the agent.

# -- Backend Connection ----------------------------------------------------
# Full base URL of the SentinelX backend including /api/v1
SENTINELX_API_BASE_URL=http://127.0.0.1:8000/api/v1

# -- Device Enrolment (recommended) -----------------------------------------
# Ask an org admin to mint a one-time code (POST /devices/enrollment-codes or
# the dashboard). On first run the agent exchanges it for a device token and
# stores that token in the OS credential store (Windows Credential Manager).
# Codes are single-use — remove this line after a successful enrolment.
SENTINELX_ENROLLMENT_CODE=

# -- Development fallback ----------------------------------------------------
# Plain-text token fallback for local development only. Leave empty when using
# enrolment; the securely stored token takes priority.
SENTINELX_DEVICE_TOKEN=

# Optional. If you know the backend device UUID you can pin it here.
SENTINELX_DEVICE_ID=

# -- Device Metadata ---------------------------------------------------------
# Hostname defaults to the machine name when unset. For the seeded TechNova
# demo laptop keep it as laptop-agent-tn-01 (org slug technova is only used by
# the legacy dev-token flow; enrolment gets the org from the code).
SENTINELX_AGENT_HOSTNAME=laptop-agent-tn-01
SENTINELX_AGENT_DISPLAY_NAME=Laptop Agent
SENTINELX_ORGANIZATION_SLUG=technova
SENTINELX_DEVICE_TYPE=desktop
SENTINELX_AGENT_TYPE=python_desktop_agent
SENTINELX_AGENT_VERSION=3.0.0

# -- Telemetry Timing --------------------------------------------------------
# Metrics interval should not be too aggressive because the backend applies
# telemetry rate limits.
SENTINELX_METRICS_INTERVAL_SECONDS=10
SENTINELX_HEARTBEAT_INTERVAL_SECONDS=30
SENTINELX_REQUEST_TIMEOUT_SECONDS=10

# -- Retry / Backoff ---------------------------------------------------------
# The agent retries transient backend/network/rate-limit failures with backoff.
SENTINELX_RETRY_MAX_ATTEMPTS=3
SENTINELX_RETRY_INITIAL_DELAY_SECONDS=2
SENTINELX_RETRY_MAX_DELAY_SECONDS=30

# -- Offline Queue ------------------------------------------------------------
# Samples are persisted to SQLite (%LOCALAPPDATA%\SentinelX\agent.db) before
# upload and flushed in idempotent batches, so outages create a backlog
# instead of a data gap.
SENTINELX_QUEUE_FLUSH_BATCH_SIZE=100
SENTINELX_QUEUE_MAX_ROWS=10000

# -- Non-Destructive Recovery Logging -----------------------------------------
# The agent does not kill processes, restart services or reboot the machine.
# It writes a recovery-action evidence record after a sustained breach.
SENTINELX_ENABLE_RECOVERY_LOGGING=true
SENTINELX_RECOVERY_COOLDOWN_SECONDS=120
SENTINELX_RECOVERY_SUSTAINED_SAMPLES=3
SENTINELX_CPU_RECOVERY_THRESHOLD=95
SENTINELX_MEMORY_RECOVERY_THRESHOLD=95
SENTINELX_DISK_RECOVERY_THRESHOLD=95
