# SentinelX Embedded Bridge — environment variables
# Copy this file to .env and fill in your values.

# ── SentinelX API ────────────────────────────────────────────
SENTINELX_API_BASE_URL=http://127.0.0.1:8000/api/v1

# Device bearer token — create one in SentinelX → Device Credentials
SENTINELX_DEVICE_TOKEN=your-device-token-here

# UUID of the Arduino device record in SentinelX (shown on Device page)
SENTINELX_DEVICE_ID=00000000-0000-0000-0000-000000000000

# ── Serial bridge ────────────────────────────────────────────
# Windows: COM3, COM4, …
# Linux/macOS: /dev/ttyACM0, /dev/ttyUSB0, …
SENTINELX_SERIAL_PORT=COM3
SENTINELX_SERIAL_BAUD=115200

# ── BLE bridge ───────────────────────────────────────────────
SENTINELX_BLE_DEVICE_NAME=SentinelX-Node
SENTINELX_BLE_SCAN_TIMEOUT=10.0
SENTINELX_BLE_SERVICE_UUID=12345678-1234-1234-1234-123456789abc
SENTINELX_BLE_CHAR_UUID=12345678-1234-1234-1234-123456789ab0

# ── Shared ───────────────────────────────────────────────────
SENTINELX_POST_TIMEOUT=8.0
SENTINELX_LOG_LEVEL=INFO
