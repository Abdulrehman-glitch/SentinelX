# ── Application ─────────────────────────────────────────────────
APP_NAME=SentinelX API
APP_ENV=development
APP_VERSION=2.0.0

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://sentinelx_app:SentinelX_app_2026!@localhost:5432/sentinelx_dev

# ── CORS Origins ─────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://10.0.2.2:5173

# ── Authentication ───────────────────────────────────────────────
# Generate a new secret for production:
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-this-dev-secret-before-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_LOGIN=15/minute
RATE_LIMIT_SIGNUP=5/minute
RATE_LIMIT_API=300/minute
RATE_LIMIT_TELEMETRY=120/minute

# ── Security Headers ─────────────────────────────────────────────
SECURITY_HEADERS_ENABLED=true

# ── Safe Recovery Orchestration (Sprint 3) ────────────────────────
# Kill switch: false disables /recovery-commands and /agent/commands
RECOVERY_ORCHESTRATION_ENABLED=true
# Path to the Ed25519 private key (generate with scripts/generate_recovery_signing_key.py)
RECOVERY_SIGNING_PRIVATE_KEY_PATH=.secrets/recovery_signing_key.pem
RECOVERY_COMMAND_DEFAULT_TTL_SECONDS=300
